#!/bin/bash
set -e

VERSION_FILE="src/version.ts"

# Read current version
current=$(grep -oE "[0-9]+\.[0-9]+\.[0-9]+" "$VERSION_FILE")
IFS='.' read -r major minor patch <<< "$current"

# Increment with rollover
if [ "$patch" -lt 9 ]; then
  patch=$((patch + 1))
else
  patch=0
  minor=$((minor + 1))
fi

new_version="$major.$minor.$patch"

# Update version file
sed -i '' "s/$current/$new_version/" "$VERSION_FILE"

# Update package.json
sed -i '' "s/\"version\": \"$current\"/\"version\": \"$new_version\"/" package.json

# Update tauri.conf.json
sed -i '' "s/\"version\": \"$current\"/\"version\": \"$new_version\"/" src-tauri/tauri.conf.json

# Update Cargo.toml
sed -i '' "s/^version = \"$current\"/version = \"$new_version\"/" src-tauri/Cargo.toml

# Update README download links
sed -i '' "s/AquaVolt_${current}/AquaVolt_${new_version}/g" README.md

# Commit the bump
git add "$VERSION_FILE" package.json src-tauri/tauri.conf.json src-tauri/Cargo.toml README.md
git commit -m "v$new_version"

echo "Version bumped: $current → $new_version"
