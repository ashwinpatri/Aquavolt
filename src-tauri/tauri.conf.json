{
  "productName": "AquaVolt",
  "version": "1.1.1",
  "identifier": "com.aquavolt.app",
  "build": {
    "beforeDevCommand": "npm run vite",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AquaVolt",
        "width": 1200,
        "height": 760,
        "minWidth": 900,
        "minHeight": 580,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../src/assets/docs/*.pdf": "docs/"
    }
  }
}
